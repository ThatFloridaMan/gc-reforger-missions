 BLUFOR1 {
  coords 5624.71 82.619 4788.972
  m_sTitle "1. SITUATION"
  m_sTextData "a. Enemy Forces:"\
  "Enemy forces are a Motorized infantry PLT. Believed to be holding around Levie and forward deployed on KT. Enemy will likely to conduct a defence in place around Levie."\
  ""\
  "b. Friendly Forces:"\
  "Adjacent units:"\
  "Dog COY is in a block position at OP Eagle facing SW towards Morton."\
  ""\
  "c. Terrain and Weather:"\
  "Terrain: A Large MSR bisects the AO In half and provide high speed approach avenue."\
  ""\
  "Terrain W & N & S of Levie is in defilade and offers poor sight lines but good concealment into Levie."\
  ""\
  "Terrain E & NE of Levie is raised and provides good sight lines into Levie."\
  ""\
  "d. Obstacles"\
  "None"
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 2
 }
