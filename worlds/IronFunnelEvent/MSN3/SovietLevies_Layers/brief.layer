 PREBRIEF {
  coords 6253.862 63.058 4719.294
  m_sTitle "Overview"
  m_sTextData "Attack COY conducts a deliberate assault on Levie, which is being defended by a Soviet motorized rifle platoon."\
  ""
  m_bEmptyFactionVisibility 1
 }
 OPFOR1 {
  coords 6299.185 64.995 4669.115
  m_sTitle "CURRENT SITUATION"
  m_sTextData "We are 331, a BTR PLT located at the Military Base south of Levie. "\
  ""\
  "Early this morning, US forces conducted a raid onto our backline depots and overran our sister COY at Simon's Woods. We are expecting US forces to conduct an assault on the town of Levie IOT break through and proceed further south into Green Valley."
  m_aVisibleForFactions {
   "USSR"
  }
  m_iOrder 2
 }
